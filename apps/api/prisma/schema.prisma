generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN  @map("admin")
  SELLER @map("seller")
  USER   @map("user")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // relations
  order      Order[]
  profilePic Photo?
  cart       Cart?

  // map
  @@map("users")
}

model Photo {
  id  String @id @default(cuid())
  url String

  // relations
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])
  userId    String  @unique @map("user_id")
  user      User    @relation(fields: [userId], references: [id])

  // map
  @@map("photos")
}

model Genre {
  id   Int    @id @default(autoincrement())
  name String @unique

  // relations
  products Product[]

  // index
  @@index([name])
  // map
  @@map("genres")
}

enum TypeMidia {
  MOVIE @map("movie")
  GAME  @map("game")
}

model MediaType {
  id   Int       @id @default(autoincrement())
  name TypeMidia @unique

  product Product[]

  @@map("media_types")
}

model Product {
  id           String  @id @default(cuid())
  price        Decimal @db.Decimal(5, 2)
  name         String
  description  String
  amount       Int
  rating       Decimal @db.Decimal(2, 1)
  shippingCost Decimal @map("shipping_cost") @db.Decimal(3, 2)

  maxInstallments      Int     @default(1) @map("max_intallments")
  freeInstallments     Int     @default(1) @map("free_intalments")
  monthlyInterestRate  Decimal @map("monthly_interest_rate") @db.Decimal(5, 4)
  minInstallmentAmount Decimal @map("min_intallment_amount") @db.Decimal(6, 2)

  discountPrice Decimal?  @map("discount_price") @db.Decimal(5, 2)
  discountStart DateTime? @map("discount_start")
  discountEnd   DateTime? @map("discount_end")

  viewCount Int @default(0) @map("view_count")

  // relations
  mediaTypeId Int           @map("media_type_id")
  mediaType   MediaType     @relation(fields: [mediaTypeId], references: [id])
  photos      Photo[]
  orderItems  OrderItem[]
  genre       Genre[]
  cartItems   CartItem[]
  view        ProductView[]

  // index
  @@index([name])
  @@index([mediaTypeId])
  @@index([price])
  @@index([discountEnd])
  @@index([rating])
  @@index([viewCount])
  // map
  @@map("products")
}

model ProductView {
  id     String   @id @default(cuid())
  viewAt DateTime @default(now()) @map("view_at")

  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([viewAt])
  @@map("product_views")
}

model Cart {
  id String @id @default(cuid())

  userId   String     @unique @map("user_id")
  user     User       @relation(fields: [userId], references: [id])
  cartItem CartItem[]

  @@map("carts")
}

model CartItem {
  id     String  @id @default(cuid())
  amount Int
  price  Decimal @db.Decimal(8, 2)

  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@map("cart_items")
}

enum OrderStatus {
  PENDING   @map("pending")
  PAID      @map("paid")
  SHIPPED   @map("shipped")
  DELIVERED @map("delivered")
  CANCELED  @map("canceled")
}

model Order {
  id          String      @id @default(cuid())
  status      OrderStatus @default(PENDING)
  totalAmount Decimal     @map("total_amount") @db.Decimal(5, 2)
  orderDate   DateTime    @default(now()) @map("order_date")
  address     String

  // relations
  userId     String      @map("user_id")
  user       User        @relation(fields: [userId], references: [id])
  orderItems OrderItem[]
  payment    Payment?

  // map
  @@map("orders")
}

model OrderItem {
  id     String  @id @default(cuid())
  amount Int
  price  Decimal @db.Decimal(5, 2)

  // relations
  orderId   String  @map("order_id")
  order     Order   @relation(fields: [orderId], references: [id])
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])

  // map
  @@map("order_items")
}

enum PaymentMethod {
  PIX         @map("pix")
  BOLETO      @map("boleto")
  DEBIT_CARD  @map("debit_card")
  CREDIT_CARD @map("credit_card")
}

enum PaymentStatus {
  PENDING    @map("pending")
  AUTHORIZED @map("authorized")
  CAPTURED   @map("captured")
  FAILED     @map("failed")
  REFUNDED   @map("refunded")
}

model Payment {
  id            Int           @id @default(autoincrement())
  paidAt        DateTime      @default(now()) @map("paid_at")
  status        PaymentStatus
  paymentMethod PaymentMethod @map("payment_method")
  installments  Int           @default(1)

  // relations
  orderId String @unique @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id])

  // map
  @@map("payments")
}
